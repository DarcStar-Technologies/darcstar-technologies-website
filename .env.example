# Drizzle — point local dev at the DEV Turso DB (the same one the Cloudflare preview Worker uses).
# The PROD DB creds live ONLY in the prod Worker's secrets + the GitHub Actions PROD_DATABASE_* secrets
# (migrate-on-merge) — never in .env. See docs/deployment.md → "Environments & databases".
DATABASE_URL="libsql://db-name-user.turso.io"
# A local DB can also be used in dev as well
# DATABASE_URL="file:local.db"
DATABASE_AUTH_TOKEN=""

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# GitHub OAuth
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Resend — contact lead notifications (issue #52) + sign-up email verification (issue #96). Leave
# blank to disable sending (contact submissions still persist; sign-up verification emails no-op).
# https://resend.com/api-keys
RESEND_API_KEY=""

# Cloudflare Turnstile — bot protection on public sign-up (issue #96, POST /sign-up/email only).
# Create a widget in the Cloudflare dashboard (Turnstile) for darcstar.tech → gives a public SITE
# key + a SECRET key. Both are read at runtime via readEnv, so both live here (wrangler types them).
# Leave BOTH blank in dev to disable captcha entirely: the widget doesn't render and Better Auth's
# captcha plugin isn't registered, so sign-up works without a challenge (graceful, like the Resend
# skip). The SITE key is public (rendered in the page); the SECRET key must stay secret — in prod set
# it with `wrangler secret put TURNSTILE_SECRET_KEY` (+ `--env preview`). See docs/auth.md.
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Sanity dataset/project (PUBLIC, BUILD-TIME). Vite inlines these `VITE_*` values into both the
# server and client bundles at build; unset → the defaults in src/lib/sanity/config.ts
# (production / 8v6ikhvv / 2026-06-24). They must be identical on server + client (an image URL embeds
# the dataset), which is why they're build-time, not a runtime readEnv. Override to point the site at
# a different dataset — e.g. VITE_SANITY_DATASET=dev while developing, or in the preview Worker's
# build env for a per-environment split. Takes effect on the next build (not a runtime toggle). Not
# secrets, so NOT wrangler secrets — set them in the build environment. See docs/sanity.md.
# VITE_SANITY_PROJECT_ID="8v6ikhvv"
# VITE_SANITY_DATASET="production"
# VITE_SANITY_API_VERSION="2026-06-24"

# Sanity — read (viewer) token for the CMS content feed (DAR-14: /news, /research, /people). The
# `production` dataset gates document READS behind document-level access control, so post/paper/person
# need an authenticated read (an anonymous request sees only `siteSettings`). Create a read/Viewer
# token in Sanity Manage → project 8v6ikhvv → API → Tokens, and set it here. Read at runtime via
# readEnv (server-only; $lib/server/sanity.ts) — never exposed to the browser. Leave blank to disable
# CMS reads in dev (the pages fall back to empty states). In prod set it with
# `wrangler secret put SANITY_VIEWER_TOKEN` (+ `--env preview` for the preview Worker). See docs/sanity.md.
SANITY_VIEWER_TOKEN=""

# Admin roster — owner allowlist for the Better Auth admin plugin (user management). Comma-separated
# user ids that are ALWAYS treated as admins (can manage the operator roster) regardless of their DB
# role, so the owner can never be locked out. This IS a Worker Env var (read at runtime via readEnv),
# so it belongs in .env (wrangler types it). Find your id with `pnpm admin:create` (it prints the id
# of an existing account). In prod set it with `wrangler secret put ADMIN_USER_IDS`.
ADMIN_USER_IDS=""

# Admin provisioning (issue #69) — inputs for `pnpm admin:create`, NOT Worker secrets (the app
# never reads them; keep them OUT of .env so wrangler doesn't type them as Env). Pass inline:
#   ADMIN_EMAIL=you@darcstar.tech ADMIN_PASSWORD='a-strong-password' pnpm admin:create
# ADMIN_NAME is optional (defaults to "Admin"). Public sign-up stays disabled; this is the only
# way to create an operator account. See docs/deployment.md.
