# Drizzle
# Replace with your DB credentials!
DATABASE_URL="libsql://db-name-user.turso.io"
# A local DB can also be used in dev as well
# DATABASE_URL="file:local.db"
DATABASE_AUTH_TOKEN=""

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# GitHub OAuth
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Resend — contact lead notifications (issue #52). Leave blank to disable sending.
# https://resend.com/api-keys
RESEND_API_KEY=""

# Admin provisioning (issue #69) — inputs for `pnpm admin:create`, NOT Worker secrets (the app
# never reads them; keep them OUT of .env so wrangler doesn't type them as Env). Pass inline:
#   ADMIN_EMAIL=you@darcstar.tech ADMIN_PASSWORD='a-strong-password' pnpm admin:create
# ADMIN_NAME is optional (defaults to "Admin"). Public sign-up stays disabled; this is the only
# way to create an operator account. See docs/deployment.md.
