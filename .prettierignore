# Generated / scaffold output — regenerated by the build (`pnpm gen`, `wrangler types`),
# `pnpm auth:schema`, or the framework scaffold; never hand-format. Paraglide's outdir has
# its own nested .gitignore, which prettier doesn't read, so list it here too. (Note:
# src/lib/paraglide.svelte.ts is NOT here — it's hand-authored app code, not generated.)
/src/lib/paraglide/
/worker-configuration.d.ts
/vitest.shims.d.ts
/src/lib/server/db/auth.schema.ts
# Sanity: types.ts is emitted by `pnpm sanity:types` (already prettier-formatted by TypeGen);
# schema.json is a verbatim copy of the Studio's `sanity schema extract` output — leave both as-is.
/src/lib/sanity/types.ts
/src/lib/sanity/schema.json

# Tool-managed inlang project metadata (gitignored, regenerated by the inlang tooling).
/project.inlang/.meta.json
/project.inlang/README.md

# Claude Code's local dir — settings, gh-user, and git worktrees (nothing here is tracked). Ignoring
